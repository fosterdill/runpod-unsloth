#!/usr/bin/env bash
# llama-chat — one-command "download from HF + run in llama-cli".
#
# Usage:
#   llama-chat <repo>[:quant] [extra llama-cli args...]
#
# Examples:
#   llama-chat unsloth/Qwen3.5-35B-A3B-GGUF                # default UD-IQ4_XS
#   llama-chat unsloth/Qwen3.5-35B-A3B-GGUF:Q4_K_M
#   llama-chat unsloth/Qwen3-30B-A3B-Instruct-GGUF:UD-IQ4_XS -c 16384
#   llama-chat unsloth/Llama-3.2-3B-Instruct-GGUF:Q8_0 --temp 0.7
#
# Defaults: -ngl 999 -c 8192 -cnv      (override by passing them again)
# Cache:    $HF_HOME (set to /workspace/.cache/huggingface on the pod, so
#           every download survives pod re-creation)
#
# Notes:
#   * Multi-shard GGUFs ("...-00001-of-00003.gguf" etc) are handled — only
#     the first shard is passed to llama-cli; it auto-discovers the rest.
#   * Pass any extra llama-cli flag after the spec; it's exec'd through.

set -euo pipefail

if [ $# -lt 1 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    sed -n '2,21p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
fi

if ! command -v hf >/dev/null 2>&1; then
    echo "llama-chat: \`hf\` CLI not found. Install with: pip install -U huggingface_hub" >&2
    exit 1
fi
if ! command -v llama-cli >/dev/null 2>&1; then
    echo "llama-chat: \`llama-cli\` not on PATH. See README → 'llama.cpp on the pod'." >&2
    exit 1
fi

spec="$1"; shift

# Split "<repo>:<quant>" — but only on the *last* colon, since some quant
# names contain hyphens (e.g. UD-IQ4_XS) but no colons, and HF repos never
# do either. Without a colon, default to UD-IQ4_XS (Unsloth Dynamic 4-bit).
if [[ "$spec" == *:* ]]; then
    repo="${spec%:*}"
    quant="${spec##*:}"
else
    repo="$spec"
    quant="UD-IQ4_XS"
fi

echo "[llama-chat] repo=${repo} quant=${quant}"
echo "[llama-chat] downloading anything matching *${quant}* (cached, so re-runs are instant)..."

# `hf download <repo> --include <pattern>` (no --local-dir) lands the files
# in the standard hub cache and prints the snapshot directory path.
snapshot=$(hf download "$repo" --include "*${quant}*")

# Pick the entrypoint file. For multi-shard GGUFs llama.cpp wants the first
# shard ("...-00001-of-NNNNN.gguf"); single-file GGUFs just match the glob.
model=""
for candidate in "${snapshot}"/*"${quant}"*-00001-of-*.gguf "${snapshot}"/*"${quant}"*.gguf; do
    if [ -f "$candidate" ]; then
        model="$candidate"
        break
    fi
done

if [ -z "$model" ]; then
    echo "[llama-chat] no .gguf matching *${quant}* in ${snapshot}" >&2
    echo "[llama-chat] files present:" >&2
    ls "${snapshot}" >&2 || true
    exit 1
fi

echo "[llama-chat] launching: $(basename "$model")"
exec llama-cli -m "$model" -ngl 999 -c 8192 -cnv "$@"
