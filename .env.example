# Copy to .env and fill in. .env is gitignored.

# Required: your RunPod API key (Settings -> API Keys -> "Create").
RUNPOD_API_KEY=

# Optional but recommended: pasted into the pod as WANDB_API_KEY so
# `wandb login` is automatic on first boot.
WANDB_API_KEY=

# Optional: HuggingFace token, used for gated/private model pulls.
HF_TOKEN=

# Optional: your SSH public key. If unset, pod.py uses ~/.ssh/id_ed25519.pub
# (or id_rsa.pub) automatically. Falls back to RunPod's account-level key
# if neither is found.
# PUBLIC_KEY="ssh-ed25519 AAAA... you@host"

# Optional: Jupyter password. If empty, Jupyter starts with no token (only
# safe because RunPod proxies it behind your account auth).
JUPYTER_PASSWORD=
